#!/usr/bin/env bash
# Recompute and write the baseline hash for skills/using-superpowers/SKILL.md.
#
# Run this ONLY after you have reviewed the diff of SKILL.md and decided the
# change is legitimate. The hash file is what protects session-start from
# injecting a tampered skill file into every future session — if you update
# it without reviewing the diff, you defeat the entire guard.
#
# Usage: bash hooks/update-skill-hash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_FILE="${PLUGIN_ROOT}/skills/using-superpowers/SKILL.md"
HASH_FILE="${SCRIPT_DIR}/.skill-hash"

if [[ ! -f "$SKILL_FILE" ]]; then
    echo "ERROR: SKILL file not found at ${SKILL_FILE}" >&2
    exit 1
fi

# Hash the file content the same way session-start does — by piping the
# content through sha256sum, not by hashing the path. This guarantees both
# sides agree on what is being authenticated.
content=$(cat "$SKILL_FILE")
hash=$(printf '%s' "${content}" | sha256sum | awk '{print $1}')

printf '%s\n' "$hash" > "$HASH_FILE"
echo "Pinned ${SKILL_FILE}"
echo "  sha256: ${hash}"
echo "  stored: ${HASH_FILE}"
echo
echo "Commit both files together so the hash and the content it pins travel as one change."
